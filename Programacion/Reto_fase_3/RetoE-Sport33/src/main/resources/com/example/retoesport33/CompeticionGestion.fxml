<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="450.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Vistas.Competicion.CompeticionGestionController">
    <top>
        <Label text="Gestión de Competiciones" BorderPane.alignment="CENTER">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
            <BorderPane.margin>
                <Insets bottom="15.0" top="15.0" />
            </BorderPane.margin>
        </Label>
    </top>
    <center>
        <TableView fx:id="tvCompeticiones" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="colCodigo" prefWidth="70.0" text="Código" />
                <TableColumn fx:id="colNombre" prefWidth="250.0" text="Nombre" />
                <TableColumn fx:id="colEstado" prefWidth="120.0" text="Estado" />
                <TableColumn fx:id="colPremio" prefWidth="120.0" text="Premio" />
            </columns>
            <BorderPane.margin>
                <Insets left="15.0" right="15.0" />
            </BorderPane.margin>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </center>
    <bottom>
        <HBox alignment="CENTER" prefHeight="80.0" spacing="20.0" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="BtnAlta" mnemonicParsing="false" onAction="#onAlta" text="Añadir" />
                <Button fx:id="BtnModificar" mnemonicParsing="false" onAction="#onModificar" text="Modificar" />
                <Button fx:id="BtnEliminar" mnemonicParsing="false" onAction="#onEliminar" text="Eliminar" />
                <Button fx:id="BtnVolver" mnemonicParsing="false" onAction="#onVolver" text="Volver">
                    <HBox.margin>
                        <Insets left="30.0" />
                    </HBox.margin>
                </Button>
            </children>
        </HBox>
    </bottom>
</BorderPane>
