<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" prefHeight="300.0" prefWidth="500.0" spacing="25" style="-fx-padding: 40; -fx-background-color: #F4F9F4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.VistaEquipo.ModificarEquipoView">
    <children>
        <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="MODIFICAR EQUIPO" />

        <VBox spacing="10" alignment="CENTER_LEFT">
            <children>
                <Label style="-fx-font-weight: bold;" text="Nombre del equipo a buscar:" />
                <TextField fx:id="tfNombre" prefHeight="40.0" promptText="Escribe el nombre..." style="-fx-background-radius: 5; -fx-border-color: #2ECC71;" />
            </children>
        </VBox>

        <HBox spacing="15" alignment="CENTER">
            <children>
                <Button fx:id="btnAceptar" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #2ECC71; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="BUSCAR" onAction="#onAceptar" />
                <Button fx:id="btnCancelar" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #95A5A6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="VOLVER" onAction="#onVolver" />
            </children>
        </HBox>
    </children>
</VBox>
