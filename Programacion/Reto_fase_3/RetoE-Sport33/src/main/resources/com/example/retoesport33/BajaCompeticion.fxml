<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="320.0" prefWidth="450.0" spacing="25" style="-fx-padding: 40; -fx-background-color: #F4F9F4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Vistas.Competicion.BaCompeticionVistaController">
    <children>
        <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="ELIMINAR COMPETICIÓN" />

        <VBox spacing="10" style="-fx-background-color: #E8F5E9; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #C8E6C9; -fx-border-radius: 10;">
            <children>
                <Label style="-fx-font-weight: bold; -fx-text-fill: #1B5E20;" text="Código de la Competición:" />
                <TextField fx:id="tfCodigo" prefHeight="40.0" promptText="Introduce el ID (ej: 101)" style="-fx-background-radius: 5; -fx-border-color: #BDC3C7;" />
            </children>
        </VBox>

        <HBox alignment="CENTER" spacing="15">
            <children>
                <Button fx:id="BtnEliminar" onAction="#onEliminar" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #1B5E20; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="ELIMINAR" />
                <Button fx:id="BtnVolver" onAction="#onVolver" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #95A5A6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="VOLVER" />
            </children>
        </HBox>
    </children>
</VBox>
